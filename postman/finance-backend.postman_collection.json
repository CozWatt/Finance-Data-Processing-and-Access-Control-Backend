{
  "info": {
    "name": "Finance Backend API",
    "_postman_id": "12345678-1234-1234-1234-123456789abc",
    "description": "Postman collection for Finance Backend with Auth, Records, Dashboard",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@finance.dev\",\n  \"password\": \"Admin@123\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "Records - Get All",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/api/records",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "records"]
        }
      }
    },
    {
      "name": "Records - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 5000,\n  \"type\": \"income\",\n  \"category\": \"salary\",\n  \"date\": \"2024-01-15\",\n  \"notes\": \"January salary\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/records",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "records"]
        }
      }
    },
    {
      "name": "Records - Filter by Amount",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/api/records?minAmount=50000",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "records"],
          "query": [
            {
              "key": "minAmount",
              "value": "50000"
            }
          ]
        }
      }
    },
    {
      "name": "Dashboard - Summary",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/api/dashboard/summary",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "dashboard", "summary"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": ""
    }
  ]
}